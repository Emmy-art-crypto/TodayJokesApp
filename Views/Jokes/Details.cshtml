@model TodayJokesApp.Models.Jokes

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Jokes</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.JokesQuestion)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.JokesQuestion)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.JokesAnswer)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.JokesAnswer)
        </dd>
    </dl>
    <
    
    @foreach (var comment in Model.Comments)
    {
        <div class="comment">
            <p>@comment.Content</p>
            <small>@comment.CreatedAt</small>
        </div>
    }
    <form asp-controller="Jokes" asp-action="AddComments" method="post">
        <input type="hidden" name="jokeId" value="@Model.Id" />

        <textarea name="Content" class="form-control"
                  placeholder="Add a comment...."></textarea>

        <button type="submit" class="btn btn-primary mt-2">
            Add Comment
        </button>
    </form>
</div>
<div>

    
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
