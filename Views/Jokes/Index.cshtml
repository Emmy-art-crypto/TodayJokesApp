@model IEnumerable<TodayJokesApp.Models.Jokes>

@{
    ViewData["Title"] = "Index";
}

<div class="container">
    <h1 class="my-4">Jokes Index</h1>

    <p>
        <a asp-action="Create" class="btn btn-primary shadow-sm">Create New</a>
    </p>

    <table class="table table-hover align-middle shadow-sm bg-white">
        <thead class="table-dark">
            <tr>
                <th>Joke Question</th>
                <th>Joke Answer</th>
                <th class="text-center">Likes</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold">@item.JokesQuestion</td>
                    <td>@item.JokesAnswer</td>

                    <!-- ✅ FIXED LIKE COUNT -->
                    <td class="text-center">
                        <span class="badge bg-light text-dark shadow-sm p-2 border">
                            👍 <strong>@(item.Likes?.Count ?? 0)</strong>
                        </span>
                    </td>

                    <td class="text-center">
                        <div class="d-flex align-items-center justify-content-center gap-3">

                            <div class="d-flex flex-column align-items-center">
                                a

                                <!-- ✅ FIXED LIKE BUTTON (POST + TOKEN) -->
                                <form asp-action="Like" asp-route-id="@item.Id" method="post" class="me-2 m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link p-0 border-0" title="Like">
                                        <i class="bi bi-hand-thumbs-up-fill text-warning shadow-sm"
                                           style="font-size: 1.5rem; filter: drop-shadow(0px 2px 2px rgba(0,0,0,0.2));"></i>
                                    </button>
                                </form>

                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm p-1 mt-1"
                                   style="font-size: 0.65rem; width: 45px;">
                                    Delete
                                </a>
                            </div>

                            <div class="d-flex flex-column gap-1">
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm text-dark px-2"
                                   style="font-size: 0.75rem;">
                                    Edit
                                </a>

                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-info btn-sm text-white px-2"
                                   style="font-size: 0.75rem;">
                                    Details
                                </a>
                            </div>

                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
}